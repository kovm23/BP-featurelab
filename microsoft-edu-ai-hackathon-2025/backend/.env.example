# Backend runtime config
FLASK_DEBUG=0
PORT=5000

# Local Ollama endpoint and fallback model.
# The UI can still send another model explicitly.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b
# API key for Ollama's OpenAI-compatible endpoint (default "ollama" works for local installs).
# OLLAMA_API_KEY=ollama
# Set to 0 to disable automatic CPU fallback when GPU model load fails.
# OLLAMA_CPU_FALLBACK=1

# Add every public frontend origin that should be allowed to call the backend.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://llmfeatures.vse.cz

# Optional but recommended in production.
# SECRET_KEY=replace-me
