# Backend API base URL
# For local development:
VITE_API_BASE=http://localhost:5000
# When the frontend is served through the Cloudflare Worker proxy, leave this unset
# so the browser stays on the same origin and requests /health, /status/*, /queue-info, etc.
# For Cloudflare tunnel:
# VITE_API_BASE=https://your-tunnel.trycloudflare.com
